cri <- c("C1", "C2", "C3")
alt <- c("A1", "A2", "A3", "A4", "A5")
pm <- cbind(
  c(5, 10, 4, 8, 1),
  c(4, 8, 2, 16, 4),
  c(7, 7, 6, 8, 5)
)
rownames(pm) <- alt
colnames(pm) <- cri
minmax <- c("max", "max", "min")
w <- c(0.25, 0.33, 0.42)
result <- mairca$new(pm, w, minmax)
}
